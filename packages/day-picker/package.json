{
  "name": "brownie-ui-day-picker",
  "version": "0.1.4",
  "description": "A highly customizable day picker component for React with i18n support and rich day information",
  "author": "Brownie UI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/brownie-ui.git",
    "directory": "packages/day-picker"
  },
  "keywords": [
    "react",
    "day-picker",
    "calendar",
    "date-picker",
    "typescript",
    "i18n",
    "spanish",
    "english",
    "brownie-ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react,brownie-ui-core",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react,brownie-ui-core",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "10 KB",
      "name": "ESM"
    },
    {
      "path": "dist/index.js",
      "limit": "10 KB",
      "name": "CJS"
    }
  ],
  "dependencies": {
    "brownie-ui-core": "0.1.3"
  },
  "devDependencies": {
    "@brownie-ui/tsconfig": "workspace:*",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "size-limit": "^12.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
